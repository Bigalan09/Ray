# ── OpenAI Responses API (primary path) ────────────────────────────
OPENAI_API_KEY=your-openai-api-key
# Optional if you use a gateway or proxy compatible with the OpenAI API.
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Legacy Azure OpenAI provider (optional) ────────────────────────
# Only needed if you reconfigure config/models.yaml to use Azure again.
# AZURE_OPENAI_API_KEY=your-azure-api-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_OPENAI_API_VERSION=2024-05-01-preview

# ── Infrastructure ─────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
# BRAVE_API_KEY=your-brave-key
