{
  "name": "ray-tests",
  "private": true,
  "scripts": {
    "test": "npx playwright test",
    "test:api": "npx playwright test --config=playwright.api.config.ts",
    "test:headed": "npx playwright test --headed",
    "test:bootstrap:live": "RAY_RUN_BOOTSTRAP_INTERACTIVE=1 npx playwright test e2e/bootstrap-interactive.spec.ts --headed",
    "test:docker": "npx playwright test --config=playwright.docker.config.ts",
    "test:docker:full": "npx playwright test --config=playwright.docker.config.ts e2e/full-coverage.spec.ts",
    "test:docker:headed": "npx playwright test --config=playwright.docker.config.ts --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
